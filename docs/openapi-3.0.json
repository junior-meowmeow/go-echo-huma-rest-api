            "description": "Created"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Create Book Page (V1)",
        "tags": [
          "Book Pages"
        ]
      }
    },
    "/v1/book_pages/offset": {
      "get": {
        "description": "Get N book pages before and after specified page number.",
        "operationId": "get-book-pages-offset-v1",
        "parameters": [
          {
            "description": "Parent Book ID",
            "explode": false,
            "in": "query",
            "name": "bookId",
            "required": true,
            "schema": {
              "description": "Parent Book ID",
              "pattern": "^[a-fA-F0-9]{24}$",
              "type": "string"
            }
          },
          {
            "description": "Center page used as the reference point",
            "explode": false,
            "in": "query",
            "name": "centerPage",
            "required": true,
            "schema": {
              "description": "Center page used as the reference point",
              "format": "int64",
              "type": "integer"
            }
          },
          {
            "description": "Number of pages to include before and after the center page",
            "explode": false,
            "in": "query",
            "name": "offset",
            "required": true,
            "schema": {
              "default": 10,
              "description": "Number of pages to include before and after the center page",
              "format": "int64",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetBookPagesResponseBody"
                }
              }
            },
            "description": "OK"
          },
          "default": {
