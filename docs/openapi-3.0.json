    "/v1/book_pages": {
      "get": {
        "description": "Get book pages in a book.",
        "operationId": "get-book-pages-v1",
        "parameters": [
          {
            "description": "Parent Book ID",
            "explode": false,
            "in": "query",
            "name": "bookId",
            "required": true,
            "schema": {
              "description": "Parent Book ID",
              "pattern": "^[a-fA-F0-9]{24}$",
              "type": "string"
            }
          },
          {
            "description": "If true, returns all items ignoring pagination",
            "explode": false,
            "in": "query",
            "name": "all",
            "required": true,
            "schema": {
              "default": false,
              "description": "If true, returns all items ignoring pagination",
              "type": "boolean"
            }
          },
          {
            "description": "Page number",
            "explode": false,
            "in": "query",
            "name": "pageNumber",
            "schema": {
              "default": 1,
              "description": "Page number",
              "format": "int64",
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "description": "Items per page",
            "explode": false,
            "in": "query",
            "name": "pageSize",
            "schema": {
              "default": 50,
              "description": "Items per page",
              "format": "int64",
              "maximum": 500,
              "minimum": 1,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetBookPagesResponseBody"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Get Book Pages (V1)",
        "tags": [
          "Book Pages"
        ]
      },
      "post": {
        "description": "Create a new book page.",
        "operationId": "create-book-page-v1",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBookPageRequestBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateBookPageResponseBody"
                }
              }
